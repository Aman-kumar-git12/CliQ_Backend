// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum UserRole {
  user
  admin
}

enum AuthProvider {
  local
  google
  hybrid
}

enum UnblockRequestStatus {
  pending
  approved
  rejected
}

model Users {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  firstname String
  lastname  String
  email     String   @unique
  age       Int
  password  String
  authProvider AuthProvider @default(local)
  googleId   String?  @unique
  role      UserRole @default(user)
  isBlocked Boolean  @default(false)
  imageUrl  String? @default("https://cyber.comolho.com/static/img/avatar.png")
  expertise Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt


  sentRequests     ConnectionsRequest[] @relation("sentRequests")
  receivedRequests ConnectionsRequest[] @relation("receivedRequests")
  comments         Comment[]
  posts Post[]
  likes    Like[]
  reports  Report[]

  conversationsIds String[] @db.ObjectId
  conversations Conversation[] @relation(fields: [conversationsIds], references: [id])
  messages      Message[]
  aiChatSessions AIChatSession[]
  unblockRequests UnblockRequest[]
}

model UnblockRequest {
  id          String               @id @default(auto()) @map("_id") @db.ObjectId
  userId      String               @db.ObjectId
  message     String
  status      UnblockRequestStatus @default(pending)
  createdAt   DateTime             @default(now())
  updatedAt   DateTime             @updatedAt

  user        Users                @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status, createdAt])
}

enum RecommendationEventType {
  shown
  saved
  ignored
  interested
}

enum RecommendationPreferenceStatus {
  none
  preferred
  not_preferred
}

enum ConnectionStatus {
  ignored
  interested
  rejected
  accepted
}

model ConnectionsRequest {
  id          String           @id @default(auto()) @map("_id") @db.ObjectId
  fromUserId  String           @db.ObjectId
  toUserId    String           @db.ObjectId
  status      ConnectionStatus @default(interested)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  fromUser Users @relation("sentRequests", fields: [fromUserId], references: [id] , onDelete: Cascade)
  toUser   Users @relation("receivedRequests", fields: [toUserId], references: [id], onDelete: Cascade)
}

model Post {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  content   String
  image     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.ObjectId
  user   Users @relation(fields: [userId], references: [id], onDelete: Cascade)
  comments Comment[]
  likes    Like[]
  reports  Report[]
}

model Comment {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  comment   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String @db.ObjectId
  user   Users @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String @db.ObjectId
  post   Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  reports Report[]
}
  

model Conversation {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  isGroup   Boolean  @default(false)
  name      String?
  image     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participantIds String[] @db.ObjectId
  participants   Users[]  @relation(fields: [participantIds], references: [id])
  
  messages     Message[]
}

enum MessageStatus {
  sent
  delivered
  seen
}

model Message {
  id            String   @id @default(auto()) @map("_id") @db.ObjectId
  text          String?
  image         String?
  file          String?
  originalName  String?
  isDelete      Boolean @default(false)
  deletedById   String[] @db.ObjectId @map("deleteybyid")

  status        MessageStatus @default(sent)

  conversationId String @db.ObjectId
  senderId       String @db.ObjectId
  parentMessageId String? @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender       Users        @relation(fields: [senderId], references: [id], onDelete: Cascade)
  parentMessage Message?    @relation("Replies", fields: [parentMessageId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies       Message[]   @relation("Replies")
}

model Like {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  createdAt DateTime @default(now())
  isLiked   Boolean  @default(true)

  userId String @db.ObjectId
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String @db.ObjectId
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Report {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  reason    String
  createdAt DateTime @default(now())

  userId String @db.ObjectId
  user   Users  @relation(fields: [userId], references: [id], onDelete: Cascade)

  postId String? @db.ObjectId
  post   Post?   @relation(fields: [postId], references: [id], onDelete: Cascade)

  commentId String?  @db.ObjectId
  comment   Comment? @relation(fields: [commentId], references: [id], onDelete: Cascade)
}

model AIChatSession {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  title     String   @default("New Chat")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  isDeleted Boolean  @default(false)

  userId    String   @db.ObjectId
  user      Users    @relation(fields: [userId], references: [id], onDelete: Cascade)

  messages  AIChatMessage[]
}

model AIChatMessage {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  role      String   // "user" or "ai"
  text      String
  createdAt DateTime @default(now())

  sessionId String   @db.ObjectId
  session   AIChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
}

model MessageAIReplyHistory {
  id             String   @id @default(auto()) @map("_id") @db.ObjectId
  userId         String   @db.ObjectId
  targetUserId   String   @db.ObjectId
  conversationId String?  @db.ObjectId
  contextSummary String
  lastMessage    String
  sentReply      String
  tone           String?
  detectedIntent String?
  topReply       String?
  generatedReplies Json?
  createdAt      DateTime @default(now())

  @@index([userId, targetUserId, createdAt])
  @@index([conversationId, createdAt])
}

model MessageAIAskHistory {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  targetUserId String   @db.ObjectId
  question     String
  answer       String
  messages     Json?
  createdAt    DateTime @default(now())

  @@index([userId, targetUserId, createdAt])
}

model RecommendationEvent {
  id              String                  @id @default(auto()) @map("_id") @db.ObjectId
  userId          String                  @db.ObjectId
  candidateUserId String                  @db.ObjectId
  action          RecommendationEventType
  source          String                  @default("smart_connections")
  metadata        Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  @@index([userId, action])
  @@index([userId, candidateUserId])
  @@index([source, createdAt])
}

model RecommendationPreference {
  id              String                         @id @default(auto()) @map("_id") @db.ObjectId
  userId          String                         @db.ObjectId
  candidateUserId String                         @db.ObjectId
  status          RecommendationPreferenceStatus @default(none)
  source          String                         @default("smart_connections")
  metadata        Json?
  createdAt       DateTime                       @default(now())
  updatedAt       DateTime                       @updatedAt

  @@unique([userId, candidateUserId])
  @@index([userId, status])
  @@index([source, updatedAt])
}
